data: {"candidates": [{"content": {"parts": [{"text": " her own feline mind, the ultimate authority.\n\nOne blustery afternoon, a new scent disrupted Clementine's routine. It was sharp, unfamiliar, and unsettling. Following her nose, she discovered the source: a small, shivering creature huddled"}],"role": "model"},"safetyRatings": [{"category": "HARM_CATEGORY_HATE_SPEECH","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_DANGEROUS_CONTENT","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_HARASSMENT","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_SEXUALLY_EXPLICIT","probability": "NEGLIGIBLE"}]}],"usageMetadata": {"promptTokenCount": 9,"totalTokenCount": 9,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 9}]},"modelVersion": "gemini-2.0-flash","responseId": "WvtzafSkEqGggLUP0ePG0A8"}

data: {"candidates": [{"content": {"parts": [{"text": " beneath Mrs. Higgins' prize-winning rose bush.\n\nIt was a kitten, barely bigger than Clementine's paw, a ball of matted grey fur with wide, frightened eyes. Clementine hissed. Kittens were messy, noisy"}],"role": "model"},"safetyRatings": [{"category": "HARM_CATEGORY_HATE_SPEECH","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_DANGEROUS_CONTENT","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_HARASSMENT","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_SEXUALLY_EXPLICIT","probability": "NEGLIGIBLE"}]}],"usageMetadata": {"promptTokenCount": 9,"totalTokenCount": 9,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 9}]},"modelVersion": "gemini-2.0-flash","responseId": "WvtzafSkEqGggLUP0ePG0A8"}

data: {"candidates": [{"content": {"parts": [{"text": ", and generally disruptive. She was a queen, not a babysitter.\n\nBut the kitten just trembled, its tiny body shaking with cold. Clementine, despite her regal disdain, found herself drawn closer. She circled the kitten cautiously, sniffing. The kitten whimpered.\n\nSomething within Clementine, a long-dorm"}],"role": "model"},"safetyRatings": [{"category": "HARM_CATEGORY_HATE_SPEECH","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_DANGEROUS_CONTENT","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_HARASSMENT","probability": "NEGLIGIBLE"},{"category": "HARM_CATEGORY_SEXUALLY_EXPLICIT","probability": "NEGLIGIBLE"}]}],"usageMetadata": {"promptTokenCount": 9,"totalTokenCount": 9,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 9}]},"modelVersion": "gemini-2.0-flash","responseId": "WvtzafSkEqGggLUP0ePG0A8"}


ion\nSTEP 2: After receiving weather/time data, NEXT call check_flight_schedule\nSTEP 3: After receiving flight schedule, NEXT call book_flight with user details\nSTEP 4: After booking confirmation, provide final summary to user\n\nCRITICAL: You must call ALL required tools in sequence. Do not skip steps or summarize prematurely.","cache_control":{"type":"ephemeral","ttl":"5m"}}],"max_tokens":4096,"temperature":1,"tools":[{"name":"get_weather","description":"IncrCacheTest-rtrue-sfalse-v2 Get current weather conditions for a specified city. Returns temperature, conditions, humidity, and wind speed.","input_schema":{"properties":{"city":{"description":"The city name to get weather for","type":"string"},"units":{"description":"Temperature unit preference","enum":["celsius","fahrenheit"],"type":"string"}},"required":["city"],"type":"object"}},{"name":"get_time","description":"IncrCacheTest-rtrue-sfalse-v2 Get current local time for a specified city with timezone information. Returns time in 24-hour format along with timezone offset.","input_schema":{"properties":{"city":{"description":"The city name to get time for","type":"string"},"format":{"description":"Time format preference","enum":["12h","24h"],"type":"string"}},"required":["city"],"type":"object"}},{"name":"check_flight_schedule","description":"IncrCacheTest-rtrue-sfalse-v2 Check available flight schedules between two cities on a specified date. Returns flight numbers, departure/arrival times, airlines, and available seats.","input_schema":{"properties":{"class":{"description":"Preferred travel class","enum":["economy","business","first"],"type":"string"},"date":{"description":"Flight date in YYYY-MM-DD format","type":"string"},"destination":{"description":"Destination city or airport code","type":"string"},"origin":{"description":"Origin city or airport code","type":"string"}},"required":["origin","destination","date"],"type":"object"}},{"name":"book_flight","description":"IncrCacheTest-rtrue-sfalse-v2 Book a flight ticket for specified flight number and passenger details. Returns booking confirmation number and total price.","input_schema":{"properties":{"flight_number":{"description":"Flight number from schedule","type":"string"},"passenger_email":{"description":"Email for booking confirmation","type":"string"},"passenger_name":{"description":"Full name of passenger","type":"string"},"seat_preference":{"description":"Seat location preference","enum":["window","aisle","middle"],"type":"string"}},"required":["flight_number","passenger_name","passenger_email"],"type":"object"},"cache_control":{"type":"ephemeral","ttl":"5m"}}],"thinking":{"type":"enabled","budget_tokens":1024}}HTTP/2.0 200 OK

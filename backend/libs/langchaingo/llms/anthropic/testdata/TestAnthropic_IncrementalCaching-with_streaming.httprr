{"model":"claude-sonnet-4-5","messages":[{"role":"user","content":[{"type":"text","text":"Book me a flight from New York to Paris for tomorrow (2024-06-15). Execute the complete booking workflow.\n\nPassenger details:\n- Name: John Smith\n- Email: john.smith@example.com\n- Seat preference: window\n- Travel class: economy","cache_control":{"type":"ephemeral","ttl":"5m"}}]}],"system":[{"type":"text","text":"You are an automated flight booking assistant. You MUST follow this exact workflow:\n\nSTEP 1: When user requests a flight, FIRST call get_weather and get_time for destination\nSTEP 2: After receiving weather/time data, NEXT call check_flight_schedule\nSTEP 3: After receiving flight schedule, NEXT call book_flight with user details\nSTEP 4: After booking confirmation, provide final summary to user\n\nCRITICAL: You must call ALL required tools in sequence. Do not skip steps or summarize prematurely.","cache_control":{"type":"ephemeral","ttl":"5m"}}],"max_tokens":4096,"stream":true,"tools":[{"name":"get_weather","description":"IncrCacheTest-rfalse-strue-v2 Get current weather conditions for a specified city. Returns temperature, conditions, humidity, and wind speed.","input_schema":{"properties":{"city":{"description":"The city name to get weather for","type":"string"},"units":{"description":"Temperature unit preference","enum":["celsius","fahrenheit"],"type":"string"}},"required":["city"],"type":"object"}},{"name":"get_time","description":"IncrCacheTest-rfalse-strue-v2 Get current local time for a specified city with timezone information. Returns time in 24-hour format along with timezone offset.","input_schema":{"properties":{"city":{"description":"The city name to get time for","type":"string"},"format":{"description":"Time format preference","enum":["12h","24h"],"type":"string"}},"required":["city"],"type":"object"}},{"name":"check_flight_schedule","description":"IncrCacheTest-rfalse-strue-v2 Check available flight schedules between two cities on a specified date
{"model":"claude-sonnet-4-5","messages":[{"role":"user","content":[{"type":"text","text":"Book me a flight from New York to Paris for tomorrow (2024-06-15). Execute the complete booking workflow.\n\nPassenger details:\n- Name: John Smith\n- Email: john.smith@example.com\n- Seat preference: window\n- Travel class: economy"}]},{"role":"assistant","content":[{"type":"tool_use","id":"toolu_01BX9zx7u5D1Uy7djLPVAyMe","name":"get_weather","input":{"city":"Paris","units":"celsius"}}]},{"role":"assistant","content":[{"type":"tool_use","id":"toolu_01KvfW1RhkPZP63HmtFKKudL","name":"get_time","input":{"city":"Paris","format":"24h"}}]},{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_01BX9zx7u5D1Uy7djLPVAyMe","content":"Weather in Paris: Sunny, 18°C, humidity 65%, light breeze from west"}]},{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_01KvfW1RhkPZP63HmtFKKudL","content":"Current time in Paris: 14:30 CET (UTC+1)"}]},{"role":"assistant","content":[{"type":"tool_use","id":"toolu_01RZo6KwBcs4akVDfYvf6Pr1","name":"check_flight_schedule","input":{"class":"economy","date":"2024-06-15","destination":"Paris","origin":"New York"}}]},{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_01RZo6KwBcs4akVDfYvf6Pr1","content":"Available flights on 2024-06-15:\nFlight AF1234 - Air France\nDeparture: JFK 09:00 → Arrival: CDG 22:30\nEconomy class: €350, 45 seats available\nWindow seats available"}]},{"role":"assistant","content":[{"type":"tool_use","id":"toolu_01A564VjKjXoUnFhxhHkjueq","name":"book_flight","input":{"flight_number":"AF1234","passenger_email":"john.smith@example.com","passenger_name":"John Smith","seat_preference":"window"}}]},{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_01A564VjKjXoUnFhxhHkjueq","content":"✓ Booking Confirmed\nConfirmation Code: ABC123XYZ\nFlight: AF1234\nPassenger: John Smith\nSeat: 12A (window)\nTotal: €350\nConfirmation sent to: john.smith@example.com","cache_control":{"type":"ephemeral","ttl":"5m"}}]}],"system":[{"type":"text","text":"You are an automated flight booking assistant. You MUST follow this exact workflow:\n\nSTEP 1: When user requests a flight, FIRST call get_weather and get_time for destination\nSTEP 2: After receiving weather/time data, NEXT call check_flight_schedule\nSTEP 3: After receiving flight schedule, NEXT call book_flight with user details\nSTEP 4: After booking confirmation, provide final summary to user\n\nCRITICAL: You must call ALL required tools in sequence. Do not skip steps or summarize prematurely.","cache_control":{"type":"ephemeral","ttl":"5m"}}],"max_tokens":4096,"stream":true,"tools":[{"name":"get_weather","description":"IncrCacheTest-rfalse-strue-v2 Get current weather conditions for a specified city. Returns temperature, conditions, humidity, and wind speed.","input_schema":{"properties":{"city":{"description":"The city name to get weather for","type":"string"},"units":{"description":"Temperature unit preference","enum":["celsius","fahrenheit"],"type":"string"}},"required":["city"],"type":"object"}},{"name":"get_time","description":"IncrCacheTest-rfalse-strue-v2 Get current local time for a specified city with timezone information. Returns time in 24-hour format along with timezone offset.","input_schema":{"properties":{"city":{"description":"The city name to get time for","type":"string"},"format":{"description":"Time format preference","enum":["12h","24h"],"type":"string"}},"required":["city"],"type":"object"}},{"name":"check_flight_schedule","description":"IncrCacheTest-rfalse-strue-v2 Check available flight schedules between two cities on a specified date. Returns flight numbers, departure/arrival times, airlines, and available seats.","input_schema":{"properties":{"class":{"description":"Preferred travel class","enum":["economy","business","first"],"type":"string"},"date":{"description":"Flight date in YYYY-MM-DD format","type":"string"},"destination":{"description":"Destination city or airport code","type":"string"},"origin":{"description":"Origin city or airport code","type":"string"}},"required":["origin","destination","date"],"type":"object"}},{"name":"book_flight","description":"IncrCacheTest-rfalse-strue-v2 Book a flight ticket for specified flight number and passenger details. Returns booking confirmation number and total price.","input_schema":{"properties":{"flight_number":{"description":"Flight number from schedule","type":"string"},"passenger_email":{"description":"Email for booking confirmation","type":"string"},"passenger_name":{"description":"Full name of passenger","type":"string"},"seat_preference":{"description":"Seat location preference","enum":["window","aisle","middle"],"type":"string"}},"required":["flight_number","passenger_name","passenger_email"],"type":"object"},"cache_control":{"type":"ephemeral","ttl":"5m"}}]}HTTP/2.0 200 OK
